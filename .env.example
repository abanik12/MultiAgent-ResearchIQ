# LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: override cost estimates (USD per 1M tokens)
# OPENAI_INPUT_PRICE_PER_1M=0.15
# OPENAI_OUTPUT_PRICE_PER_1M=0.60

# Search (Phase 2+)
TAVILY_API_KEY=
# Limit total web links across the full run to the N most recent (not per sub-task)
WEB_SEARCH_RECENT_LIMIT_ENABLED=false
WEB_SEARCH_RECENT_LIMIT=30

# Vector Store (Phase 2+)
# local = embedded Qdrant on disk (no Docker). server = connect to QDRANT_URL (docker compose up -d)
QDRANT_MODE=local
QDRANT_LOCAL_PATH=data/qdrant_storage
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=researchiq
BM25_INDEX_PATH=data/bm25_index.json
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Skip Hugging Face cross-encoder reranking in Doc Analyst (faster research runs)
RAG_SKIP_RERANK=false

# Notion (Phase 4)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Observability (optional)
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=researchiq
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
